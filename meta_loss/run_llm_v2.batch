#!/bin/bash
#SBATCH --account=brics.s5e
#SBATCH --partition=workq
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=72
#SBATCH --gres=gpu:1
#SBATCH --time=02:00:00
#SBATCH --output=results/llm_v2_%j.out
#SBATCH --error=results/llm_v2_%j.err

set -euo pipefail

# ── Python env ──────────────────────────────────────────
# conda shebangs point to stale /home path; python3 is ELF binary (fine)
# base env packages are at miniforge3/lib/python3.12/site-packages/
export PATH="/projects/s5e/quant/miniforge3/bin:$PATH"
export CONDA_PREFIX="/projects/s5e/quant/miniforge3"
export LD_LIBRARY_PATH="/projects/s5e/quant/miniforge3/lib:/projects/s5e/quant/miniforge3/lib/python3.12/site-packages/torch/lib:${LD_LIBRARY_PATH:-}"
echo "[$(date)] Python: $(python3 --version) at $(which python3)"

# ── Antigravity Manager (LLM API proxy) ────────────────
echo "[$(date)] Starting Antigravity Manager..."
apptainer run \
    --env API_KEY="${LLM_API_KEY:-sk-c95e13f4ccea4d91ae24e4c132fd6971}" \
    --env ABV_PORT="${LLM_PORT:-18045}" \
    --env ABV_BIND_LOCAL_ONLY=true \
    /projects/s5e/quant/antigravity-manager_latest.sif > /dev/null 2>&1 &
AG_PID=$!

for i in $(seq 1 30); do
    if curl -s --connect-timeout 2 http://127.0.0.1:${LLM_PORT:-18045}/v1/models > /dev/null 2>&1; then
        echo "[$(date)] Antigravity Manager ready (attempt $i)"
        break
    fi
    sleep 2
done

if ! curl -s --connect-timeout 5 http://127.0.0.1:${LLM_PORT:-18045}/v1/models > /dev/null 2>&1; then
    echo "[$(date)] ERROR: Antigravity Manager failed to start"
    kill $AG_PID 2>/dev/null
    exit 1
fi

# ── GPU info ────────────────────────────────────────────
echo "[$(date)] GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null || echo 'N/A')"

# ── Run LLM+Conversation v2 ────────────────────────────
cd /projects/s5e/quant/fingan/FlowFM_v2/meta_loss

ROUNDS=${ROUNDS:-20}
N_SEEDS=${N_SEEDS:-3}
RESUME_FLAG=""
if [ -n "${RESUME:-}" ] && [ -f "results/llm_fingan_v2/messages.json" ]; then
    RESUME_FLAG="--resume results/llm_fingan_v2/messages.json"
fi

echo "[$(date)] Starting LLM+Conversation v2: ROUNDS=$ROUNDS N_SEEDS=$N_SEEDS"
python3 evolve_llm_fingan.py --rounds "$ROUNDS" --n_seeds "$N_SEEDS" $RESUME_FLAG

EXIT_CODE=$?
echo "[$(date)] LLM v2 finished with exit code $EXIT_CODE"

kill $AG_PID 2>/dev/null
wait $AG_PID 2>/dev/null
exit $EXIT_CODE
